{
  "name": "ccwire",
  "description": "CC-to-CC communication protocol - enables real-time messaging between Claude Code sessions via MCP",
  "version": "0.6.1",
  "author": {
    "name": "Chronista Club",
    "url": "https://github.com/chronista-club"
  },
  "repository": "https://github.com/chronista-club/claude-plugin-ccwire",
  "keywords": [
    "communication",
    "protocol",
    "multi-session",
    "tmux",
    "messaging",
    "mcp"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/register.sh"
          }
        ]
      }
    ]
  }
}
